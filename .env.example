# VLM OCR Document Reader - Environment Variables

# Gemini API Key (required for integration tests)
GEMINI_API_KEY=your_gemini_api_key_here

# Qwen/DashScope API Key (optional, for OCR via Qwen VL)
# Use QWEN_API_KEY or DASHSCOPE_API_KEY (alias)
# QWEN_API_KEY=your_qwen_api_key_here
# DASHSCOPE_API_KEY=your_dashscope_api_key_here

# Logging level
VLM_LOG_LEVEL=INFO
